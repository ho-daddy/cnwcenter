// Prisma 스키마 파일
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 모델
model User {
  id              String      @id @default(cuid())
  email           String      @unique
  emailVerified   DateTime?
  name            String?
  password        String?     // 소셜 로그인 시 null 가능
  image           String?
  role            UserRole    @default(WORKPLACE_USER)
  status          UserStatus  @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedReason  String?
  resetToken      String?     // 비밀번호 재설정 토큰
  resetExpires    DateTime?   // 비밀번호 재설정 토큰 만료시간
  phone           String?     // 전화번호
  organization    String?     // 소속사업장
  privacyAgreedAt DateTime?   // 개인정보 수집·이용 동의 일시
  
  // 튜토리얼 완료 상태
  tutorialCompletedRiskAssessment Boolean @default(false)
  tutorialCompletedMusculoskeletal Boolean @default(false)
  tutorialCompletedWorkplaces Boolean @default(false)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // 관계
  accounts        Account[]
  sessions        Session[]
  counselingCases CounselingCase[]
  schedules       Schedule[]
  workplaces      WorkplaceUser[]
  musculoskeletalAssessments MusculoskeletalAssessment[]  // 근골조사 (작성자)
  notices         Notice[]                               // 공지사항 작성
  noticeComments  NoticeComment[]                        // 공지사항 댓글
  surveys         Survey[]                               // 설문조사 (작성자)
  archivedDeletions ArchivedAssessment[]                 // 삭제한 아카이브
  uploadedVideos    WorkVideo[]                          // 업로드한 작업 영상
  popups            Popup[]                              // 생성한 팝업
}

enum UserRole {
  SUPER_ADMIN      // 최고관리자 - 모든 권한
  STAFF            // 새움터 스탭 - 시스템 설정 제외 모든 권한
  WORKPLACE_USER   // 사업장 사용자 - 소속 사업장의 위험성평가, 근골조사만
}

enum UserStatus {
  PENDING    // 승인 대기
  APPROVED   // 승인됨
  REJECTED   // 거부됨
  SUSPENDED  // 정지됨
}

// NextAuth Account (소셜 로그인 계정 연결)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth VerificationToken (이메일 인증용)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 사업장 모델
model Workplace {
  id            String   @id @default(cuid())
  name          String                    // 사업장명
  industry      String?                   // 업종
  products      String?  @db.Text         // 주요생산품 및 서비스
  address       String?                   // 소재지
  employeeCount Int?                      // 인원규모
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         WorkplaceUser[]
  contacts      WorkplaceContact[]        // 담당자 (복수)
  organization  Organization?              // 조직도 (사업장당 1개)
  musculoskeletalAssessments MusculoskeletalAssessment[]  // 근골조사
  archivedAssessments ArchivedAssessment[]  // 아카이브된 조사
  riskAssessmentCards        RiskAssessmentCard[]         // 위험성평가 관리카드
  chemicalProducts           ChemicalProduct[]            // 화학제품
  surveys                    Survey[]                     // 설문조사
}

// 담당자 유형
enum ContactType {
  SAFETY_OFFICER       // 안전보건업무 담당자
  UNION_REPRESENTATIVE // 노동조합 안전보건담당자
}

// 사업장 담당자
model WorkplaceContact {
  id          String      @id @default(cuid())
  workplaceId String
  workplace   Workplace   @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  contactType ContactType
  name        String                      // 담당자명
  position    String?                     // 직책
  phone       String?                     // 전화번호
  email       String?                     // 이메일
  isPrimary   Boolean     @default(false) // 대표 담당자 여부
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([workplaceId])
  @@index([contactType])
}

// 조직도 (사업장당 1개)
model Organization {
  id          String   @id @default(cuid())
  workplaceId String   @unique            // 사업장당 1개 보장
  workplace   Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units       OrganizationUnit[]
}

// 조직 단위 (부서-공정-작업 등 5단계 계층)
model OrganizationUnit {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         OrganizationUnit?  @relation("UnitHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       OrganizationUnit[] @relation("UnitHierarchy")

  name           String                    // 조직 단위명
  level          Int                       // 1~5 단계
  sortOrder      Int      @default(0)      // 정렬 순서
  isLeaf         Boolean  @default(false)  // 최하단 = 평가대상 여부

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  musculoskeletalAssessments MusculoskeletalAssessment[]  // 근골조사
  riskAssessmentCards        RiskAssessmentCard[]         // 위험성평가 관리카드
  noiseMeasurements          NoiseMeasurement[]           // 소음 측정값
  chemicalProductUnits       ChemicalProductUnit[]        // 사용 화학물질

  @@index([organizationId])
  @@index([parentId])
  @@index([level])
}

// 사용자-사업장 연결 (다대다)
model WorkplaceUser {
  id          String    @id @default(cuid())
  userId      String
  workplaceId String
  assignedAt  DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workplace   Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workplaceId])
  @@index([userId])
  @@index([workplaceId])
}

// 일정 관리
model Schedule {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  startDate    DateTime
  endDate      DateTime?
  isAllDay     Boolean      @default(false) // 종일 일정 여부
  location     String?      // 장소
  isOnline     Boolean      @default(false) // 온라인 여부
  scheduleType ScheduleType @default(GENERAL)
  relatedId    String?      // 상담/위험성평가/근골조사 ID (향후 연동용)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@index([startDate])
  @@index([scheduleType])
}

enum ScheduleType {
  GENERAL           // 일반 일정
  COUNSELING        // 상담
  RISK_ASSESSMENT   // 위험성평가
  MUSCULOSKELETAL   // 근골조사
  MEETING_ROOM      // 회의실 사용
}

// 상담 케이스 관리
model CounselingCase {
  id              String            @id @default(cuid())
  caseNumber      String            @unique
  victimName      String                              // 재해자 성명 (필수)
  victimContact   String                              // 연락처 (필수)
  workplaceName   String?                             // 사업장명
  caseType        CaseType?                           // 사고/질병/출퇴근
  diseaseCategory DiseaseCategory?                    // 질병분류
  accidentDate    DateTime?                           // 재해일시
  accidentType    String?                             // 재해유형 (레거시)
  diagnosisDate   DateTime?                           // 진단일시
  diagnosisName   String?                             // 진단명
  guardianName    String?                             // 보호자 성명
  guardianContact String?                             // 보호자 연락처
  status          CaseStatus        @default(RECEIVED)
  assignedTo      String
  user            User              @relation(fields: [assignedTo], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // 관계
  consultations   Consultation[]
  documents       Document[]

  @@index([assignedTo])
  @@index([status])
  @@index([caseNumber])
  @@index([caseType])
}

enum CaseStatus {
  RECEIVED              // 접수
  IN_PROGRESS           // 진행중
  APPLICATION_COMPLETE  // 신청완료
  RESULT_NOTIFIED       // 결과통보
  OBJECTION             // 이의제기
  CLOSED                // 종결
}

enum CaseType {
  ACCIDENT   // 사고
  DISEASE    // 질병
  COMMUTE    // 출퇴근
}

enum DiseaseCategory {
  TRAUMA           // 외상
  MUSCULOSKELETAL  // 근골격계
  CARDIOVASCULAR   // 뇌심혈관계
  NOISE_HEARING    // 소음성난청
  OTHER            // 기타
}

// 상담 기록
model Consultation {
  id              String         @id @default(cuid())
  caseId          String
  case            CounselingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  consultDate     DateTime
  consultType     String         // 전화, 방문, 이메일 등
  content         String         @db.Text
  nextAction      String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([caseId])
  @@index([consultDate])
}

// 문서 관리
model Document {
  id          String         @id @default(cuid())
  caseId      String
  case        CounselingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  uploadedAt  DateTime       @default(now())

  @@index([caseId])
}

// 뉴스/브리핑
model NewsBriefing {
  id              String    @id @default(cuid())
  title           String
  content         String    @db.Text
  source          String    // 소스명 (예: '고용노동부')
  sourceId        String    // 하드코딩 소스 ID (예: 'moel')
  url             String?
  linkHash        String    @unique // URL 해시 (중복 방지)
  priority        String?   // critical/high/medium/low/none
  matchedKeywords  String?   @db.Text // 매칭된 키워드 (JSON 배열)
  relevanceScore   Int?      // AI 관련성 점수 (0-100)
  relevanceReason  String?   @db.Text // AI 판단 이유
  isRelevant       Boolean   @default(true) // 브리핑 포함 여부 (70점 이상)
  publishedAt      DateTime
  collectedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@index([publishedAt])
  @@index([sourceId])
  @@index([linkHash])
  @@index([priority])
  @@index([isRelevant])
}

// 수집 상태
enum CollectionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// 수집 로그
model CollectionLog {
  id            String           @id @default(cuid())
  sourceId      String           // 하드코딩 소스 ID
  sourceName    String
  status        CollectionStatus
  articlesCount Int              @default(0)
  errorMessage  String?          @db.Text
  startedAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime         @default(now())

  @@index([sourceId])
  @@index([createdAt])
  @@index([status])
}

// 일일 리포트 (AI 분석 결과)
model DailyReport {
  id            String   @id @default(cuid())
  date          DateTime @unique // 브리핑 날짜
  topIssuesJson String   @db.Text // 3대 이슈 JSON
  analysisJson  String   @db.Text // 상세 분석 JSON
  insightsText  String   @db.Text // 실무 시사점
  markdownPath  String?  // 저장된 마크다운 파일 경로
  articleCount  Int      // 수집된 기사 수
  filteredCount Int      // 필터링된 기사 수
  createdAt     DateTime @default(now())

  @@index([date])
}

// ==========================================
// 위험성평가 시스템
// ==========================================

enum HazardCategory {
  ACCIDENT         // 사고성재해
  MUSCULOSKELETAL  // 근골격계질환
  CHEMICAL         // 유해화학물질
  NOISE            // 소음
  ABSOLUTE         // 절대기준
  OTHER            // 기타위험
}

enum RiskEvaluationType {
  REGULAR      // 정기조사
  OCCASIONAL   // 수시조사
}

enum ImprovementStatus {
  PLANNED    // 예정
  COMPLETED  // 완료
}

// 관리카드 (공정별 위험성평가 기본정보, 기존 assessment_cards)
model RiskAssessmentCard {
  id                 String             @id @default(cuid())
  workplaceId        String
  workplace          Workplace          @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  organizationUnitId String
  organizationUnit   OrganizationUnit   @relation(fields: [organizationUnitId], references: [id])

  year               Int
  evaluationType     RiskEvaluationType
  evaluationReason   String?            @db.Text  // 수시조사 사유
  workerName         String
  evaluatorName      String

  dailyWorkingHours  String?
  dailyProduction    String?
  annualWorkingDays  String?
  workCycle          String?
  workDescription    String             @db.Text

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  hazards            RiskHazard[]
  photos             RiskCardPhoto[]

  @@unique([organizationUnitId, year, evaluationType])
  @@index([workplaceId])
  @@index([organizationUnitId])
  @@index([year])
}

// 관리카드 사진 (기존 assessment_card_photos)
model RiskCardPhoto {
  id            String             @id @default(cuid())
  cardId        String
  card          RiskAssessmentCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  photoPath     String
  thumbnailPath String?
  width         Int?
  height        Int?
  photoType     String             @default("work_photo")  // work_photo | hazard_photo
  description   String?            @db.Text

  createdAt     DateTime           @default(now())

  @@index([cardId])
}

// 유해위험요인 (기존 assessments)
model RiskHazard {
  id                String             @id @default(cuid())
  cardId            String
  card              RiskAssessmentCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  workplaceId       String

  hazardCategory    HazardCategory
  hazardFactor      String             @db.Text

  // 위험성 점수 구성 (riskScore = severity × likelihood + additional)
  severityScore     Int                // 중대성 1~5
  likelihoodScore   Int                // 가능성 1~5
  additionalPoints  Int                @default(0)  // 가점 0~3
  additionalDetails Json?              // 가점 상세 { key: value } e.g. { "accidentJudgement": 1, "accidentExperience": 0 }
  riskScore         Int                // 앱에서 계산 후 저장

  improvementPlan   String?            @db.Text
  year              Int

  // 유해화학물질 카테고리일 때 화학제품 직접 연결
  chemicalProductId String?
  chemicalProduct   ChemicalProduct?   @relation(fields: [chemicalProductId], references: [id], onDelete: SetNull)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  photos            RiskHazardPhoto[]
  improvements      RiskImprovementRecord[]

  @@index([cardId])
  @@index([workplaceId])
  @@index([hazardCategory])
  @@index([year])
  @@index([riskScore])
  @@index([chemicalProductId])
}

// 유해위험요인 사진 (기존 assessment_photos)
model RiskHazardPhoto {
  id            String     @id @default(cuid())
  hazardId      String
  hazard        RiskHazard @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  photoPath     String
  thumbnailPath String?
  width         Int?
  height        Int?

  createdAt     DateTime   @default(now())

  @@index([hazardId])
}

// 개선작업 이력 (기존 improvement_records)
model RiskImprovementRecord {
  id                 String            @id @default(cuid())
  hazardId           String
  hazard             RiskHazard        @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  status             ImprovementStatus
  updateDate         DateTime          @db.Date   // 예정일 또는 완료일
  improvementContent String            @db.Text
  responsiblePerson  String

  // 개선 후 위험성 점수
  severityScore      Int
  likelihoodScore    Int
  additionalPoints   Int               @default(0)
  riskScore          Int               // 앱에서 계산 후 저장

  remarks            String?           @db.Text

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  photos             RiskImprovementPhoto[]
  files              RiskImprovementFile[]

  @@index([hazardId])
  @@index([status])
  @@index([updateDate])
}

// 개선작업 사진 (기존 improvement_record_photos)
model RiskImprovementPhoto {
  id            String                @id @default(cuid())
  recordId      String
  record        RiskImprovementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  photoPath     String
  thumbnailPath String?
  width         Int?
  height        Int?

  createdAt     DateTime              @default(now())

  @@index([recordId])
}

// 개선작업 첨부파일 (기존 improvement_record_files)
model RiskImprovementFile {
  id        String                @id @default(cuid())
  recordId  String
  record    RiskImprovementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  fileName  String
  filePath  String
  fileSize  Int?

  createdAt DateTime              @default(now())

  @@index([recordId])
}

// ==========================================
// 화학물질 관리 (MSDS)
// ==========================================

// 화학 성분 마스터 DB (전역 - CAS 번호 기반, 기존 chemical_components)
model ChemicalComponent {
  id          String             @id @default(cuid())
  casNumber   String             @unique  // CAS 번호
  name        String
  hazards     String?            @db.Text  // 유해성 정보 (MSDS B02 섹션)
  regulations String?            @db.Text  // 규제사항 (MSDS O02 섹션)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  products    ProductComponent[]

  @@index([casNumber])
  @@index([name])
}

// 화학제품 (사업장별, 기존 chemical_products)
model ChemicalProduct {
  id            String              @id @default(cuid())
  workplaceId   String
  workplace     Workplace           @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  name          String
  manufacturer  String?
  description   String?             @db.Text
  severityScore Int?                // 구성성분 중 최대 중대성점수 (자동산정)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  components    ProductComponent[]
  hazardUsages  RiskHazard[]        // 이 화학물질이 참조된 평가항목
  unitLinks     ChemicalProductUnit[] // 사용 공정/부서 연결 ← 핵심

  @@index([workplaceId])
  @@index([name])
  @@index([severityScore])
}

// 제품-성분 연결 (기존 product_components)
model ProductComponent {
  id            String            @id @default(cuid())
  productId     String
  product       ChemicalProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  componentId   String
  component     ChemicalComponent @relation(fields: [componentId], references: [id])

  concentration String?           // 함유량: "30", "모름", "영업비밀"
  severityScore Int?              // 이 성분의 중대성점수 (MSDS 룰 자동산정)

  @@unique([productId, componentId])
  @@index([productId])
  @@index([componentId])
}

// 화학물질-조직단위 연결
// 기존 department_products + process_products 두 테이블을 단일 테이블로 통합.
// OrganizationUnit이 부서/공정을 모두 표현하므로 레벨 구분 없이 하나의 관계로 충분.
//
// 연결 시점:
//   1. [자동] 유해화학물질 RiskHazard 저장 시 해당 관리카드의 OrganizationUnit 자동 연결
//   2. [수동] 화학제품 등록/수정 화면에서 부서/공정 직접 지정
//
// 지원 쿼리:
//   - "이 화학물질을 사용하는 부서/공정은?" → filter by chemicalProductId
//   - "이 공정에서 사용하는 화학물질은?"    → filter by organizationUnitId
model ChemicalProductUnit {
  chemicalProductId  String
  chemicalProduct    ChemicalProduct  @relation(fields: [chemicalProductId], references: [id], onDelete: Cascade)
  organizationUnitId String
  organizationUnit   OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)

  linkedAt           DateTime         @default(now())

  @@id([chemicalProductId, organizationUnitId])
  @@index([chemicalProductId])
  @@index([organizationUnitId])
}

// ==========================================
// 소음 측정값
// ==========================================

enum NoisePeriod {
  recent    // 최근 측정값
  previous  // 전회 측정값
}

// 소음 측정값 (공정별·연도별, 기존 noise_measurements)
// OrganizationUnit(공정 레벨)에 연결. 평가 시 중대성점수 자동 제안에 활용.
model NoiseMeasurement {
  id                 String           @id @default(cuid())
  organizationUnitId String
  organizationUnit   OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)

  year               Int
  period             NoisePeriod
  measurementValue   Decimal          @db.Decimal(5, 2)  // dB 값 (소수점 1자리)
  notes              String?          @db.Text

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([organizationUnitId, year, period])
  @@index([organizationUnitId])
  @@index([year])
}

// ==========================================
// 공지사항
// ==========================================

// 공지사항 (기존 notices)
model Notice {
  id        String          @id @default(cuid())
  title     String
  content   String?         @db.Text
  authorId  String
  author    User            @relation(fields: [authorId], references: [id])
  isPinned  Boolean         @default(false)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  comments  NoticeComment[]
  images    NoticeImage[]

  @@index([authorId])
  @@index([createdAt])
  @@index([isPinned])
}

// 공지사항 댓글 (기존 comments)
model NoticeComment {
  id        String   @id @default(cuid())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noticeId])
  @@index([authorId])
}

// 공지사항 본문 이미지 (기존 notice_image_upload.php로 업로드)
model NoticeImage {
  id        String   @id @default(cuid())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  imagePath String
  fileName  String
  fileSize  Int?

  createdAt DateTime @default(now())

  @@index([noticeId])
}

// ==========================================
// 근골격계 유해요인 조사 (근골조사)
// ==========================================

// 근골조사 상태
enum MSurveyStatus {
  DRAFT           // 작성중
  IN_PROGRESS     // 조사진행중
  COMPLETED       // 조사완료
  REVIEWED        // 검토완료
}

// 부담부위 (6개)
enum BodyPart {
  HAND_WRIST      // 손/손목
  ELBOW_FOREARM   // 팔꿈치/아래팔
  SHOULDER_ARM    // 어깨/위팔
  NECK            // 목
  BACK_HIP        // 허리/고관절
  KNEE_ANKLE      // 무릎/발목
}

// 근골조사 메인 모델 (공정당 연도+유형별 복수 등록 가능)
model MusculoskeletalAssessment {
  id                 String        @id @default(cuid())
  workplaceId        String
  workplace          Workplace     @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  organizationUnitId String
  organizationUnit   OrganizationUnit @relation(fields: [organizationUnitId], references: [id])

  year               Int           // 조사년도
  assessmentType     String        // 정기조사, 수시조사
  status             MSurveyStatus @default(DRAFT)

  // 1번시트 (관리카드) 필드
  workerName         String?       // 작업자
  investigatorName   String?       // 조사자
  occasionalReason   String?       // 수시조사 사유 (질환자발생/설비변화/작업방법변경/기타)
  occasionalReasonCustom String?   // 수시조사 기타 사유
  dailyWorkHours     Float?        // 1일작업시간
  dailyProduction    String?       // 1일생산량
  workFrequency      String?       // 작업빈도 (상시/간헐)
  employmentType     String?       // 고용형태
  workDays           String?       // 작업일수 (주5일/주6일/기타)
  workDaysCustom     String?       // 작업일수 기타 직접입력
  shiftType          String?       // 교대근무형태
  shiftTypeCustom    String?       // 교대근무형태 기타 직접입력
  jobAutonomy        Int?          // 직무자율성 (1-3)

  // 기타 위험요인 (체크박스)
  hasNoise           Boolean       @default(false)
  hasThermal         Boolean       @default(false)
  hasBurn            Boolean       @default(false)
  hasDust            Boolean       @default(false)
  hasAccident        Boolean       @default(false)  // 사고성재해
  hasStress          Boolean       @default(false)  // 스트레스
  hasOtherRisk       Boolean       @default(false)  // 기타 위험요인
  otherRiskDetail    String?                         // 기타 위험요인 직접입력

  // 부담부위 체크 (1번시트)
  affectedHandWrist     Boolean    @default(false)
  affectedElbow         Boolean    @default(false)
  affectedShoulder      Boolean    @default(false)
  affectedNeck          Boolean    @default(false)
  affectedBack          Boolean    @default(false)
  affectedKnee          Boolean    @default(false)

  // 작업조건 변화 (최근3년) - 변화있음/변화없음
  changeWorkHours    String?       // 변화있음/변화없음
  changeWorkSpeed    String?
  changeManpower     String?
  changeWorkload     String?
  changeEquipment    String?

  // 참조
  reference          String?       @db.Text  // 자유형식 참조

  // 4번시트 (종합평가카드) 필드
  managementLevel    String?       // 상/중상/중/하
  overallComment     String?       @db.Text

  // 생략 옵션
  skipSheet2         Boolean       @default(false)  // 2번시트(부위별점수) 생략
  skipSheet3         Boolean       @default(false)  // 3번시트(RULA/REBA) 생략

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  createdById        String?
  createdBy          User?         @relation(fields: [createdById], references: [id])

  // 관계
  elementWorks       ElementWork[]
  improvements       MSurveyImprovement[]
  attachments        MSurveyAttachment[]

  @@unique([organizationUnitId, year, assessmentType])  // 단위+연도+유형 유니크
  @@index([workplaceId])
  @@index([organizationUnitId])
  @@index([year])
  @@index([status])
  @@index([createdById])
}

// 아카이브된 데이터 (삭제 시 백업)
model ArchivedAssessment {
  id                   String   @id @default(cuid())
  workplaceId          String
  workplace            Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  dataType             String   @default("MUSCULOSKELETAL")  // MUSCULOSKELETAL | RISK_ASSESSMENT | RISK_HAZARD | RISK_IMPROVEMENT | ELEMENT_WORK
  unitName             String              // 삭제된 조직 단위명
  unitPath             String              // "생산본부 > 조립팀 > 나사조립"
  assessmentData       Json                // 전체 데이터 (JSON 스냅샷)
  year                 Int                 // 조사/평가 년도
  assessmentType       String              // 정기조사, 수시조사 등
  originalAssessmentId String              // 원본 ID (참조용)
  archivedAt           DateTime @default(now())
  archivedReason       String?             // "조직 단위 삭제", "직접 삭제" 등
  deletedById          String?
  deletedBy            User?    @relation(fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([workplaceId])
  @@index([year])
  @@index([dataType])
  @@index([deletedById])
}

// 요소작업 모델 (요소작업당 1개 = 2,3번시트)
model ElementWork {
  id            String                    @id @default(cuid())
  assessmentId  String
  assessment    MusculoskeletalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  sortOrder     Int                       // 요소작업 순번 (1, 2, 3...)
  name          String                    // 요소작업명
  description   String?       @db.Text    // 작업내용

  // 2번시트 상단: 작업특성
  toolWeight       Float?                 // 공구무게 (kg)
  loadWeight       Float?                 // 중량물 무게 (kg)
  loadFrequency    Int?                   // 중량물 빈도 (회/일)
  pushPullForce    Float?                 // 밀고당기기 (kgf)
  pushPullFreq     Int?                   // 밀고당기기 빈도 (회/일)
  vibrationSource  String?                // 전신진동발생원
  vibrationHours   Float?                 // 진동노출시간 (시간/일)

  // 3번시트: RULA/REBA 관련
  rulaScore        Int?
  rulaLevel        String?                // 안전/보통/위험/고위험
  rebaScore        Int?
  rebaLevel        String?
  pushPullArm      String?                // 팔 평가결과
  pushPullHand     String?                // 손 평가결과
  pushPullFinger   String?                // 손가락 평가결과

  // 3번시트: 상세 입력값 저장 (JSON)
  rulaInputs          Json?              // RULA 상세 입력값 (재로딩용)
  rebaInputs          Json?              // REBA 상세 입력값 (재로딩용)
  pushPullEvaluations Json?              // 밀고당기기 개별 측정값 평가

  // 3번시트: 추가입력 (체크박스)
  hasArmSupport    Boolean   @default(false)  // 팔이 지탱된 상태
  hasUnstableLeg   Boolean   @default(false)  // 다리/발 불안정
  hasRapidPosture  Boolean   @default(false)  // 급속 자세변경
  hasRapidForce    Boolean   @default(false)  // 급격한 힘 사용

  // 3번시트: 추가입력 (선택)
  kneePosture      String?                // 무릎 자세 (0~30도/30~60도 등)
  handleQuality    String?                // 손잡이 상태 (양호/보통/불충분)

  // 4번시트: 요소작업별 평가결과
  evaluationResult String?       @db.Text  // 종합평가 시 주관식 평가결과

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  // 관계
  bodyPartScores   BodyPartScore[]
  improvements     MSurveyImprovement[]
  measurements     WorkMeasurement[]
  videos           WorkVideo[]           // 작업 영상

  @@index([assessmentId])
}

// 공구·중량물·밀고당기기·전신진동 측정 모델 (요소작업당 각 유형 최대 10개)
enum MeasurementType {
  TOOL         // 공구
  LOAD         // 중량물
  PUSH_PULL    // 밀고당기기
  VIBRATION    // 전신진동
}

model WorkMeasurement {
  id              String          @id @default(cuid())
  elementWorkId   String
  elementWork     ElementWork     @relation(fields: [elementWorkId], references: [id], onDelete: Cascade)

  type            MeasurementType
  sortOrder       Int             @default(0)

  name            String                    // 공구명/중량물명/물체명칭/발생원
  weight          Float?                    // 무게(kg) - TOOL, LOAD
  force           Float?                    // 힘(kgf) - PUSH_PULL
  frequency       Int?                      // 빈도(회/일) - LOAD, PUSH_PULL
  exposureHours   Float?                    // 노출시간(시간/일) - VIBRATION
  photoPath       String?                   // 사진 경로

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([elementWorkId])
  @@index([type])
}

// 부담부위별 점수 모델 (요소작업당 6개)
model BodyPartScore {
  id              String      @id @default(cuid())
  elementWorkId   String
  elementWork     ElementWork @relation(fields: [elementWorkId], references: [id], onDelete: Cascade)

  bodyPart        BodyPart

  // 각도 입력값 (JSON - 부위별로 다름)
  angles          Json?       // { flexion: 30, extension: 0, rotation: 15, ... }

  // 부가점수 체크박스들 (JSON)
  additionalFactors Json?     // { toolOver1kg: true, vibration: false, ... }

  // 계산된 점수
  postureScore    Int         @default(0)  // 자세 기본점수 (max 5)
  additionalScore Int         @default(0)  // 부가점수 합계
  totalScore      Int         @default(0)  // 총점 (1-7)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([elementWorkId, bodyPart])
  @@index([elementWorkId])
}

// 개선사항 모델 (4번시트 하단)
model MSurveyImprovement {
  id                String                    @id @default(cuid())
  assessmentId      String
  assessment        MusculoskeletalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  elementWorkId     String?
  elementWork       ElementWork?  @relation(fields: [elementWorkId], references: [id], onDelete: SetNull)

  documentNo        String?                   // 참조 문서번호
  problem           String        @db.Text    // 주요 문제점
  improvement       String        @db.Text    // 개선 검토 방향
  source            String?                   // 수집경로

  status            ImprovementStatus?        // 예정/완료
  updateDate        DateTime?     @db.Date    // 예정일 또는 완료일
  responsiblePerson String?                   // 담당자
  remarks           String?       @db.Text    // 비고

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([assessmentId])
  @@index([elementWorkId])
  @@index([status])
}

// 첨부파일 모델 (사진/영상)
model MSurveyAttachment {
  id            String                    @id @default(cuid())
  assessmentId  String
  assessment    MusculoskeletalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  elementWorkId String?                   // 특정 요소작업에 연결된 경우

  fileName      String                    // 저장된 파일명 (공정명_요소작업명_001.jpg)
  originalName  String                    // 원본 파일명
  fileType      String                    // image/jpeg, video/mp4 등
  fileSize      Int                       // 바이트
  filePath      String                    // 저장 경로

  createdAt     DateTime      @default(now())

  @@index([assessmentId])
  @@index([elementWorkId])
}

// ─── 설문조사 (Survey) ───

enum SurveyStatus {
  DRAFT        // 작성중
  PUBLISHED    // 배포중
  CLOSED       // 마감
}

enum QuestionType {
  TEXT           // 텍스트 입력
  NUMBER         // 숫자 입력
  RADIO          // 단일 선택
  CHECKBOX       // 다중 선택
  RANGE          // 범위 슬라이더
  DROPDOWN       // 드롭다운
  TABLE          // 표/그리드 입력
  RANKED_CHOICE  // 순위 선택
  CONSENT        // 동의 체크
}

// 설문 템플릿 (재사용 가능)
model SurveyTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  structure   Json                       // 전체 섹션/질문 구조 JSON
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  surveys     Survey[]

  @@index([isDefault])
}

// 설문조사
model Survey {
  id            String        @id @default(cuid())
  title         String
  description   String?       @db.Text
  year          Int
  purpose       String?                   // 설문 목적/용도
  workplaceId   String?
  workplace     Workplace?    @relation(fields: [workplaceId], references: [id], onDelete: SetNull)
  templateId    String?
  template      SurveyTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  status        SurveyStatus  @default(DRAFT)
  accessToken   String?       @unique     // 공개 URL 토큰
  publishedAt   DateTime?
  closedAt      DateTime?

  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sections      SurveySection[]
  responses     SurveyResponse[]

  @@index([workplaceId])
  @@index([year])
  @@index([status])
  @@index([createdById])
}

// 설문 섹션
model SurveySection {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  sortOrder   Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   SurveyQuestion[]

  @@index([surveyId])
}

// 설문 질문
model SurveyQuestion {
  id             String       @id @default(cuid())
  sectionId      String
  section        SurveySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  questionCode   String?                  // 코드 (S0-name, Q1-1 등) - 조건분기 참조용
  questionText   String       @db.Text
  questionType   QuestionType
  required       Boolean      @default(false)
  sortOrder      Int

  options        Json?                    // 유형별 설정 (선택지, min/max, columns/rows 등)
  conditionalLogic Json?                  // 조건부 로직 {conditions, logicType}

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  answers        SurveyAnswer[]

  @@index([sectionId])
  @@index([questionCode])
}

// 설문 응답 (1명의 응답세트)
model SurveyResponse {
  id             String    @id @default(cuid())
  surveyId       String
  survey         Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  respondentName String?
  respondentInfo Json?                   // 인적사항 요약 (부서, 공정 등)
  completedAt    DateTime?

  createdAt      DateTime  @default(now())

  answers        SurveyAnswer[]

  @@index([surveyId])
  @@index([completedAt])
}

// 개별 답변
model SurveyAnswer {
  id          String         @id @default(cuid())
  responseId  String
  response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  value       Json                       // 답변 값 (타입별 형태 상이)

  createdAt   DateTime       @default(now())

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
}

// ============================================
// 작업 영상 관리 (근골조사/위험성평가 현장 촬영)
// ============================================

enum VideoUploadStatus {
  PROCESSING  // 처리 중
  UPLOADING   // 업로드 중
  UPLOADED    // 완료
  FAILED      // 실패
}

model WorkVideo {
  id              String            @id @default(cuid())

  // 요소작업 연결 (근골조사)
  elementWorkId   String
  elementWork     ElementWork       @relation(fields: [elementWorkId], references: [id], onDelete: Cascade)

  // 공정 정보
  processName     String            // 공정명 (요소작업명과 동일하거나 상세 설명)
  recorder        String            // 촬영자명
  recordedAt      DateTime          @default(now()) // 촬영 일시

  // Google Drive 파일 정보
  driveFileId     String?           @unique
  driveUrl        String?           @db.Text
  thumbnailUrl    String?           @db.Text

  // 파일 메타데이터
  fileName        String            // 원본 파일명
  mimeType        String            @default("video/webm")
  originalSize    BigInt?           // bytes
  durationSec     Int?              // 영상 길이 (초)
  resolution      String?           // "1920x1080"

  // 업로드 상태
  status          VideoUploadStatus @default(PROCESSING)
  uploadProgress  Int               @default(0) // 0-100
  errorMessage    String?           @db.Text

  // 업로드한 사용자
  uploadedById    String
  uploadedBy      User              @relation(fields: [uploadedById], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([elementWorkId])
  @@index([status])
  @@index([uploadedById])
}

// 팝업 관리
model Popup {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([isActive, startDate, endDate])
  @@index([createdById])
}
